#%PAM-1.0

# pam_systemd.so deve rodar ANTES de pam_gnome_keyring.so na session
# para que o user@.service (e o dbus-daemon) subam antes do keyring
# tentar se conectar. Sem essa ordem, o auto-unlock falha intermitentemente
# com "senha incorreta" no primeiro login apos reiniciar.

auth       required     pam_securetty.so
auth       requisite    pam_nologin.so
auth       include      system-local-login
auth       optional     pam_gnome_keyring.so
account    include      system-local-login
session    include      system-local-login
session    required     pam_systemd.so
session    optional     pam_gnome_keyring.so auto_start
