# UWSM Environment Variables Configuration
# This file is sourced automatically by UWSM when launching the desktop session.

# Force Wayland Native execution for applications
export MOZ_ENABLE_WAYLAND=1
export NIXOS_OZONE_API=1
export ELECTRON_OZONE_PLATFORM_HINT=wayland

# Qt theme and toolkit configuration
export QT_QPA_PLATFORM=wayland
export QT_QPA_PLATFORMTHEME=qt6ct

# Default system tools
export EDITOR=nvim
export TERMINAL=kitty
