#!/usr/bin/env bash
# gabrln - Script de instalação Arch-gabrln (Hyprland + Noctalia v5)
#
# Uso:
#   sudo ./gabrln                 # instalação completa
#   sudo ./gabrln --dry-run       # simula sem modificar nada
#   sudo ./gabrln --verbose       # habilita logs de DEBUG
#   sudo ./gabrln --quiet         # suprime INFO, mantém ERROR/STEP
#
# Flags:
#   --dry-run   Apenas simula (não executa módulos destrutivos)
#   --verbose   Habilita logs de DEBUG
#   --quiet     Suprime INFO, mantém ERROR/STEP
#   --force     Re-executa módulos já concluídos (ignora state.json)
#
# Variáveis de ambiente:
#   NO_COLOR=1    Desabilita saída colorida (https://no-color.org/)
#
# Requer root (execute via `sudo bash install.sh`).

set -euo pipefail

SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
REPO_DIR=$(cd "$SCRIPT_DIR/.." && pwd)
INSTALLER_DIR="$REPO_DIR/installer"
CONFIG_FILE="$INSTALLER_DIR/config.toml"
MODULES_DIR="$INSTALLER_DIR/modules"
MANIFESTS_DIR="$INSTALLER_DIR/manifests"

export REPO_DIR INSTALLER_DIR CONFIG_FILE MODULES_DIR MANIFESTS_DIR

# --- Bibliotecas -------------------------------------------------------------

# shellcheck source=SCRIPTDIR/lib/logger.sh
source "$INSTALLER_DIR/lib/logger.sh"
# shellcheck source=SCRIPTDIR/lib/utils.sh
source "$INSTALLER_DIR/lib/utils.sh"
# shellcheck source=SCRIPTDIR/lib/errors.sh
source "$INSTALLER_DIR/lib/errors.sh"
# shellcheck source=SCRIPTDIR/lib/state.sh
source "$INSTALLER_DIR/lib/state.sh"
# shellcheck source=SCRIPTDIR/lib/backup.sh
source "$INSTALLER_DIR/lib/backup.sh"
# shellcheck source=SCRIPTDIR/lib/progress.sh
source "$INSTALLER_DIR/lib/progress.sh"

# --- Parse de flags ----------------------------------------------------------

VERBOSE="${VERBOSE:-0}"
QUIET="${QUIET:-0}"
DRY_RUN=0
FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    -h|--help)
      sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
      exit 0
      ;;
    --verbose) VERBOSE=1; shift ;;
    --quiet)   QUIET=1;   shift ;;
    --dry-run) DRY_RUN=1; shift ;;
    --force)   FORCE=1;   shift ;;
    --no-color) export NO_COLOR=1; shift ;;
    *)
      log_error "Opção desconhecida: $1"
      sed -n '2,20p' "$0" | sed 's/^# \{0,1\}//'
      exit 1
      ;;
  esac
done

export VERBOSE QUIET

# --- Inicialização -----------------------------------------------------------

LOGS_DIR="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.logs_dir" "installer/logs")"
log_init "$LOGS_DIR"

setup_traps
detect_real_user

# Polkit policy: libera gabrln-helper via pkexec para o usuário real
# (sem re-prompt de senha). Removida automaticamente no EXIT.
if [[ "$(toml_get "$CONFIG_FILE" "features.enable_polkit_helper" "true")" == "true" ]]; then
  setup_polkit_policy
else
  log_info "Polkit helper desabilitado em config.toml."
fi

# Estado persistente + diretório de backups
init_framework() {
  local state_dir backups_dir
  state_dir="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.state_dir" "installer/state")"
  backups_dir="$REPO_DIR/$(toml_get "$CONFIG_FILE" "paths.backups_dir" "installer/state/backups")"

  state_init "$state_dir"
  backup_init "$backups_dir"
  register_cleanup "toml_cache_cleanup"
}
init_framework

# Coleta paths para backup a partir do manifesto de dotfiles.
_collect_backup_paths() {
  local paths=()

  while IFS= read -r cfg; do
    [[ -n "$cfg" ]] && paths+=("$USER_HOME/.config/$cfg")
  done < <(toml_list "$MANIFESTS_DIR/dotfiles.toml" "directories.configs")

  paths+=("$USER_HOME/.config/zsh")

  while IFS= read -r f; do
    [[ -n "$f" ]] && paths+=("$f")
  done < <(python3 -c '
import sys, tomllib, os
file, home = sys.argv[1], sys.argv[2]
with open(file, "rb") as f:
    data = tomllib.load(f)
for src, dst in data.get("files", {}).items():
    expanded = os.path.expandvars(dst)
    if expanded.startswith("~"):
        expanded = home + expanded[1:]
    print(expanded)
' "$MANIFESTS_DIR/dotfiles.toml" "$USER_HOME")

  paths+=("/etc/greetd")
  paths+=("/etc/pam.d/greetd")

  printf '%s\n' "${paths[@]}"
}

# --- Execução de módulo ------------------------------------------------------
#
# run_module <nome> <manifesto>
#
# Se o módulo já foi concluído com o mesmo manifesto (state.json), pula.
# Se --dry-run, simula. Caso contrário, source o módulo (compartilha o shell).
# Falha do módulo aborta a instalação inteira.
run_module() {
  local module="$1"
  local manifest="${2:-}"
  local module_path="$MODULES_DIR/$module.sh"

  if [[ ! -f "$module_path" ]]; then
    log_warn "Módulo $module não encontrado em $module_path. Pulando."
    return 0
  fi

  if [[ "$FORCE" -eq 0 && -n "$manifest" ]] && state_is_up_to_date "$module" "$manifest"; then
    log_info "Módulo $module já está atualizado. Pulando."
    return 0
  fi

  if [[ "$DRY_RUN" -eq 1 ]]; then
    log_step "[dry-run] $module seria executado"
    return 0
  fi

  log_step "Executando módulo $module"

  # set +e no wrapper para capturarmos o exit code do módulo sem matar
  # o caller via `set -e` herdado. Restaura no final.
  local saved_e
  saved_e=$(set +o | grep errexit || true)
  set +e
  # shellcheck source=/dev/null
  source "$module_path"
  local rc=$?
  eval "$saved_e"

  if [[ $rc -ne 0 ]]; then
    state_mark_failed "$module" "exit $rc"
    exit_with_error "Módulo $module falhou com exit code $rc." "$rc"
  fi

  if [[ -n "$manifest" ]]; then
    state_mark_done "$module" "$manifest"
  else
    state_mark_done "$module"
  fi
}

# --- Lista de módulos (ordem fixa) -------------------------------------------
#
# Módulos source'd em ordem. O manifesto (quando presente) é usado para
# cache: se o hash do manifesto não mudou, o módulo é pulado.
MODULES=(
  "00-preflight"
  "01-backup:dotfiles.toml"
  "02-pacman-bootstrap"
  "03-pacman-official:packages.toml"
  "04-yay-aur:aur.toml"
  "05-flatpak:flatpak.toml"
  "06-curl-tools:curl-tools.toml"
  "07-shell:zsh-plugins.toml"
  "08-dotfiles:dotfiles.toml"
  "09-hyprland-env"
  "10-greeter"
  "11-keyring"
  "13-wallpapers:wallpapers.toml"
  "14-icons-cursors-fonts"
  "15-system-tweaks"
  "16-services:services.toml"
)

# --- Instalação --------------------------------------------------------------

log_step "Iniciando instalação Arch-gabrln"
log_info "REPO_DIR: $REPO_DIR"
log_info "REAL_USER: $REAL_USER"
log_info "USER_HOME: $USER_HOME"

progress_init "${#MODULES[@]}" "install"

for entry in "${MODULES[@]}"; do
  # entry é "nome" ou "nome:manifesto"
  module="${entry%%:*}"
  manifest_name="${entry#*:}"
  manifest=""
  if [[ "$manifest_name" != "$entry" && -n "$manifest_name" ]]; then
    manifest="$MANIFESTS_DIR/$manifest_name"
  fi

  progress_step "$module"
  run_module "$module" "$manifest"
done

progress_done "Instalação"
log_success "Instalação Arch-gabrln concluída com sucesso."
